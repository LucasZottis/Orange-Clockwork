---
import Layout from '../layouts/Layout.astro';
---

<style>
  @import "../styles/pomodoro.css";
</style>

<Layout title="Pomodoro" activePage="pomodoro">
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-12">

    <!-- Mode Switcher -->
    <div class="flex justify-center mb-12">
      <div class="mode-switcher">
        <button id="btn-pomodoro" class="mode-btn active-mode px-6 py-2.5 rounded-lg text-sm font-semibold transition-all" data-mode="pomodoro" data-duration="1500">
          Pomodoro
        </button>
        <button id="btn-short" class="mode-btn px-6 py-2.5 rounded-lg text-sm font-medium transition-all" data-mode="short" data-duration="300">
          Pausa Curta
        </button>
        <button id="btn-long" class="mode-btn px-6 py-2.5 rounded-lg text-sm font-medium transition-all" data-mode="long" data-duration="900">
          Pausa Longa
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

      <!-- ── Timer Section ─────────────────────────────────────── -->
      <section class="lg:col-span-7 flex flex-col items-center justify-center relative" style="min-height: 560px;">

        <!-- Ambient glow -->
        <div class="pomodoro-glow absolute -z-10 w-96 h-96 rounded-full top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>

        <!-- Session label -->
        <p id="session-label" class="label-xs mb-8" style="color: var(--color-on-surface-variant); letter-spacing: 0.3em;">Sessão de Trabalho Profundo</p>

        <!-- Breath ring + SVG progress + timer display -->
        <div class="relative flex flex-col items-center">
          <!-- SVG Progress Ring -->
          <svg id="progress-ring" class="absolute pointer-events-none -rotate-90" style="inset: -4rem; width: calc(100% + 8rem); height: calc(100% + 8rem);">
            <circle cx="50%" cy="50%" fill="transparent" r="48%" stroke-width="2" style="stroke: rgba(255, 140, 0, 0.1);"></circle>
            <circle id="ring-progress" cx="50%" cy="50%" fill="transparent" r="48%" stroke-width="2" stroke-dasharray="0 10000" stroke-linecap="round" style="stroke: var(--color-primary);"></circle>
          </svg>

          <div class="pomodoro-ring w-[280px] h-[280px] md:w-[380px] md:h-[380px]">
            <div class="pomodoro-ring-pulse animate-pulse"></div>
            <div id="timer-display" class="timer-display select-none" style="font-size: clamp(3.5rem, 12vw, 7rem);">
              25<span class="timer-sep">:</span>00
            </div>
          </div>
        </div>

        <!-- Controls -->
        <div class="mt-16 flex items-center gap-8 md:gap-12">
          <button id="btn-reset" class="group flex flex-col items-center gap-2" title="Reiniciar">
            <div class="btn-control w-14 h-14 rounded-full flex items-center justify-center">
              <span class="material-symbols-outlined">replay</span>
            </div>
            <span class="label-xs" style="color: var(--color-on-surface-variant); opacity: 0.6;">Reiniciar</span>
          </button>

          <button id="btn-start" class="btn-start w-24 h-24 rounded-full flex items-center justify-center relative overflow-hidden transition-all hover:scale-105 active:scale-95">
            <span id="start-icon" class="material-symbols-outlined text-4xl relative z-10" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
          </button>

          <button id="btn-skip" class="group flex flex-col items-center gap-2" title="Pular">
            <div class="btn-control w-14 h-14 rounded-full flex items-center justify-center">
              <span class="material-symbols-outlined">skip_next</span>
            </div>
            <span class="label-xs" style="color: var(--color-on-surface-variant); opacity: 0.6;">Pular</span>
          </button>
        </div>
      </section>

      <!-- ── Sidebar ────────────────────────────────────────────── -->
      <div class="lg:col-span-5 flex flex-col gap-6">

        <!-- Focus Task Card -->
        <div class="focus-card">
          <div class="flex justify-between items-start mb-4">
            <div>
              <span class="label-xs" style="color: var(--color-primary);">Foco Atual</span>
              <h2 id="focus-title" class="focus-title">Minha Tarefa</h2>
            </div>
            <button id="btn-edit-focus" class="btn-control w-10 h-10 rounded-full flex items-center justify-center">
              <span class="material-symbols-outlined" style="font-size: 1.125rem;">edit</span>
            </button>
          </div>
          <div id="focus-edit" class="hidden mb-4">
            <input
              id="focus-input"
              type="text"
              placeholder="Em que você está trabalhando?"
              class="time-input text-sm"
            />
          </div>
          <p id="focus-desc" class="focus-desc">
            Defina sua tarefa de foco para acompanhar seu progresso durante a sessão Pomodoro.
          </p>
        </div>

        <!-- Session Progress Card -->
        <div class="session-progress-card">
          <div class="flex justify-between items-center mb-5">
            <span class="label-xs" style="color: var(--color-on-surface-variant);">Progresso da Sessão</span>
            <span class="label-xs" style="color: var(--color-primary);">
              Sessão <span id="session-count">1</span> de 4
            </span>
          </div>

          <!-- Session dots -->
          <div class="flex gap-3 mb-5">
            {Array.from({ length: 4 }).map((_, i) => (
              <div class="session-dot flex-1 h-2 rounded-full border-2 transition-all duration-300" data-index={i}></div>
            ))}
          </div>

          <!-- Goal progress -->
          <div class="progress-track w-full h-1.5 rounded-full overflow-hidden">
            <div id="goal-progress" class="progress-fill h-full rounded-full transition-all duration-500" style="width: 0%;"></div>
          </div>
          <div class="flex justify-between mt-2">
            <span class="label-xs" style="color: var(--color-on-surface-variant); opacity: 0.6;">
              <span id="sessions-done">0</span> sessões concluídas
            </span>
            <span class="label-xs" style="color: var(--color-on-surface-variant); opacity: 0.6;">Meta: 4</span>
          </div>
        </div>

        <!-- Stats Card -->
        <div class="stats-card">
          <span class="material-symbols-outlined mb-4 block" style="color: var(--color-primary);">schedule</span>
          <h3 class="font-headline font-bold text-lg" style="color: var(--color-on-surface);">Técnica Pomodoro</h3>
          <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-on-surface-variant);">
            Trabalhe por <strong style="color: var(--color-primary);">25 minutos</strong>, depois faça uma pausa de
            <strong style="color: var(--color-tertiary);">5 minutos</strong>. Após 4 sessões, faça uma pausa longa de
            <strong style="color: var(--color-tertiary);">15 minutos</strong>.
          </p>
        </div>

        <!-- Up Next -->
        <div class="upcoming-card">
          <span class="label-xs mb-4 block" style="color: var(--color-on-surface-variant);">A Seguir</span>
          <div class="space-y-3" id="upcoming-list">
            <div class="flex items-center gap-3">
              <div class="upcoming-item-dot"></div>
              <span class="upcoming-item-text">Pausa Curta (5 min)</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="upcoming-item-dot"></div>
              <span class="upcoming-item-text">Segunda Sessão de Trabalho</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>

<script>
  import '../scripts/pomodoro';
</script>
