---
import Layout from '../layouts/Layout.astro';
import '../styles/countdown.css';
---

<Layout title="Contagem Regressiva" activePage="countdown">
  <div class="max-w-7xl mx-auto px-6 pt-12 pb-24">

    <!-- Main Grid: Left config + Right timer -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

      <!-- ── Left Column: Configuration ── -->
      <div class="lg:col-span-4 space-y-8">

        <!-- Header -->
        <div>
          <span class="text-primary font-bold text-xs uppercase tracking-widest block mb-2">
            Configuração
          </span>
          <h1 class="text-4xl font-extrabold tracking-tight text-on-surface">
            Tempo
          </h1>
        </div>

        <!-- Config Card -->
        <div class="bg-surface-container p-6 rounded-xl space-y-6">

          <!-- Manual Entry -->
          <div class="space-y-4">
            <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">
              Entrada Manual
            </label>
            <div class="flex items-center gap-3">

              <div class="flex-1">
                <input
                  id="input-hours"
                  class="time-input"
                  type="number" min="0" max="23"
                  value="0"
                  placeholder="00"
                />
                <span class="input-label block mt-1 px-1">Horas</span>
              </div>

              <span class="text-2xl font-bold text-outline-variant">:</span>

              <div class="flex-1">
                <input
                  id="input-minutes"
                  class="time-input"
                  type="number" min="0" max="59"
                  value="25"
                  placeholder="25"
                />
                <span class="input-label block mt-1 px-1">Minutos</span>
              </div>

              <span class="text-2xl font-bold text-outline-variant">:</span>

              <div class="flex-1">
                <input
                  id="input-seconds"
                  class="time-input"
                  type="number" min="0" max="59"
                  value="0"
                  placeholder="00"
                />
                <span class="input-label block mt-1 px-1">Segundos</span>
              </div>

            </div>
          </div>

          <!-- Presets -->
          <div class="space-y-4">
            <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">
              Predefinições
            </label>
            <div class="grid grid-cols-2 gap-3">
              <button class="preset-btn" data-seconds="900">15:00</button>
              <button class="preset-btn" data-seconds="1500">25:00</button>
              <button class="preset-btn" data-seconds="2700">45:00</button>
              <button class="preset-btn" data-seconds="3600">60:00</button>
            </div>
          </div>

          <!-- Alarm Tone -->
          <div class="space-y-4 pt-2">
            <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">
              Tom de Alarme
            </label>
            <div class="flex flex-col gap-2">

              <button class="alarm-btn active-alarm" data-alarm="chime">
                <div class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-primary">graphic_eq</span>
                  <span class="text-sm font-medium">Sino Sutil</span>
                </div>
                <span class="material-symbols-outlined alarm-check icon-filled">check_circle</span>
              </button>

              <button class="alarm-btn" data-alarm="bell">
                <div class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-on-surface-variant">music_note</span>
                  <span class="text-sm">Sino Clássico</span>
                </div>
                <span class="material-symbols-outlined alarm-play">play_circle</span>
              </button>

              <button class="alarm-btn" data-alarm="digital">
                <div class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-on-surface-variant">notifications</span>
                  <span class="text-sm">Digital</span>
                </div>
                <span class="material-symbols-outlined alarm-play">play_circle</span>
              </button>

            </div>
          </div>

        </div>

      </div>

      <!-- ── Right Column: Signature Timer ── -->
      <div class="lg:col-span-8 flex flex-col items-center justify-center min-h-[614px] relative">

        <!-- Atmosphere glow -->
        <div class="countdown-atmosphere" aria-hidden="true"></div>

        <!-- Timer content -->
        <div class="relative z-10 text-center">

          <!-- Breath Ring -->
          <div class="breath-ring absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[320px] h-[320px] md:w-[480px] md:h-[480px] rounded-full border border-primary/20 flex items-center justify-center">
            <div class="w-[300px] h-[300px] md:w-[450px] md:h-[450px] rounded-full border-4 border-dashed border-primary/30 spin-slow"></div>
          </div>

          <!-- Time + Stats -->
          <div class="relative">
            <span class="text-primary font-manrope text-sm uppercase tracking-[0.3em] font-bold block mb-4">
              Tempo Restante
            </span>

            <div id="timer-display" class="countdown-timer-display justify-center">
              <!-- Populated by countdown.ts -->
              <span>25</span><span class="timer-colon">:</span><span>00</span>
            </div>

            <!-- Stats Row -->
            <div class="flex justify-center gap-12 mt-8">
              <div class="text-center">
                <span id="stat-sessions" class="block text-3xl font-bold">00</span>
                <span class="text-[10px] uppercase tracking-widest text-on-surface-variant font-bold">Sessões</span>
              </div>
              <div class="text-center">
                <span id="stat-minutes" class="block text-3xl font-bold text-tertiary">000</span>
                <span class="text-[10px] uppercase tracking-widest text-on-surface-variant font-bold">Minutos</span>
              </div>
              <div class="text-center">
                <span id="stat-streak" class="block text-3xl font-bold">00</span>
                <span class="text-[10px] uppercase tracking-widest text-on-surface-variant font-bold">Sequências</span>
              </div>
            </div>
          </div>

        </div>

        <!-- Status Badge -->
        <div id="status-badge" class="status-badge status-badge-ready mt-8 relative z-10">
          Pronto para Iniciar
        </div>

        <!-- Controls -->
        <div class="mt-8 flex items-center gap-8 relative z-10">

          <button
            id="btn-reset"
            class="w-16 h-16 rounded-full flex items-center justify-center bg-surface-container-highest text-on-surface-variant hover:text-primary transition-all"
            aria-label="Reiniciar"
          >
            <span class="material-symbols-outlined text-3xl">replay</span>
          </button>

          <button
            id="btn-start"
            class="h-24 w-24 rounded-full bg-primary text-on-primary flex items-center justify-center shadow-[0_0_50px_rgba(255,140,0,0.3)] hover:scale-105 active:scale-95 transition-all"
            aria-label="Iniciar"
          >
            <span id="start-icon" class="material-symbols-outlined text-5xl icon-filled">play_arrow</span>
          </button>

          <button
            id="btn-stop"
            class="w-16 h-16 rounded-full flex items-center justify-center bg-surface-container-highest text-on-surface-variant hover:text-primary transition-all"
            aria-label="Parar"
          >
            <span class="material-symbols-outlined text-3xl">stop</span>
          </button>

        </div>

      </div>
    </div>

  </div>
</Layout>

<script>
  import '../scripts/countdown';
</script>
