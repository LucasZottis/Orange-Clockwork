---
import Layout from '../layouts/Layout.astro';
---

<style>
  @import "../styles/stopwatch.css";
</style>

<Layout title="Cronômetro" activePage="stopwatch">
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

      <!-- ── Main Timer ─────────────────────────────────────── -->
      <section class="lg:col-span-8 flex flex-col items-center justify-center relative" style="min-height: 560px;">

        <!-- Ambient glow -->
        <div class="stopwatch-glow absolute -z-10 w-96 h-96 rounded-full top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>

        <!-- Session label -->
        <p class="label-xs mb-8" style="color: var(--color-on-surface-variant); letter-spacing: 0.3em;">Sessão Atual</p>

        <!-- Breath ring + SVG progress + timer display -->
        <div class="relative flex flex-col items-center">
          <!-- SVG Progress Ring (DESIGN.md §5 Breath Ring) -->
          <svg id="progress-ring" class="absolute pointer-events-none -rotate-90" style="inset: -4rem; width: calc(100% + 8rem); height: calc(100% + 8rem);">
            <circle cx="50%" cy="50%" fill="transparent" r="48%" stroke-width="2" style="stroke: rgba(255, 140, 0, 0.1);"></circle>
            <circle id="ring-progress" cx="50%" cy="50%" fill="transparent" r="48%" stroke-width="2" stroke-dasharray="0 10000" stroke-linecap="round" style="stroke: var(--color-primary);"></circle>
          </svg>

          <div class="stopwatch-ring w-[280px] h-[280px] md:w-[380px] md:h-[380px]">
            <div class="stopwatch-ring-pulse animate-pulse"></div>
            <h1 id="timer-display" class="timer-display select-none" style="font-size: clamp(3.5rem, 12vw, 7rem);"><span id="time-main">00:00:00</span><span id="ms-display" class="timer-sep" style="font-size: clamp(1.25rem, 4vw, 2.5rem);">.00</span></h1>
          </div>
        </div>

        <!-- Controls -->
        <div class="mt-16 flex items-center gap-8 md:gap-12">
          <button id="btn-reset" class="group flex flex-col items-center gap-2">
            <div class="btn-control w-14 h-14 rounded-full flex items-center justify-center">
              <span class="material-symbols-outlined">replay</span>
            </div>
            <span class="label-xs" style="color: var(--color-on-surface-variant); opacity: 0.6;">Reiniciar</span>
          </button>

          <button id="btn-start" class="btn-start w-24 h-24 rounded-full flex items-center justify-center relative overflow-hidden transition-all hover:scale-105 active:scale-95">
            <span id="start-icon" class="material-symbols-outlined text-4xl relative z-10" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
          </button>

          <button id="btn-lap" class="group flex flex-col items-center gap-2">
            <div class="btn-control w-14 h-14 rounded-full flex items-center justify-center">
              <span class="material-symbols-outlined">flag</span>
            </div>
            <span class="label-xs" style="color: var(--color-on-surface-variant); opacity: 0.6;">Volta</span>
          </button>
        </div>
      </section>

      <!-- ── Sidebar ────────────────────────────────────────── -->
      <div class="lg:col-span-4 flex flex-col gap-6">

        <!-- Lap Records Card -->
        <div class="lap-records-card">
          <div class="flex justify-between items-start mb-6 shrink-0">
            <div>
              <h2 class="lap-records-heading">Registro de Voltas</h2>
              <p class="lap-records-subtext">Intervalos da sessão</p>
            </div>
            <span id="lap-count-badge" class="lap-badge text-xs px-3 py-1 shrink-0">0 Voltas</span>
          </div>

          <div id="laps-list" class="lap-list space-y-2">
            <div id="laps-empty" class="lap-list-empty">Nenhuma volta registrada ainda</div>
          </div>
        </div>

        <!-- Stats Card -->
        <div class="stats-card">
          <span class="material-symbols-outlined mb-4 block" style="color: var(--color-primary);">insights</span>
          <h3 class="font-headline font-bold text-lg" style="color: var(--color-on-surface);">Estatísticas</h3>
          <div class="mt-4 space-y-3">
            <div>
              <p class="stats-label">Melhor Volta</p>
              <p id="best-lap" class="stats-value">--:--:--</p>
            </div>
            <div>
              <p class="stats-label">Última Volta</p>
              <p id="last-lap" class="stats-value">--:--:--</p>
            </div>
          </div>
        </div>

        <!-- Clear Laps -->
        <div class="btn-clear group" id="btn-clear-laps">
          <div class="w-12 h-12 rounded-full flex items-center justify-center shrink-0" style="background-color: var(--color-surface-container-highest);">
            <span class="material-symbols-outlined" style="color: var(--color-on-surface-variant);">delete_sweep</span>
          </div>
          <div>
            <h3 class="font-headline font-bold text-sm" style="color: var(--color-on-surface);">Limpar Voltas</h3>
            <p class="stats-label mt-1">Apagar registros</p>
          </div>
          <span class="material-symbols-outlined ml-auto group-hover:translate-x-1 transition-transform" style="color: var(--color-on-surface-variant); opacity: 0.4;">chevron_right</span>
        </div>

      </div>
    </div>
  </div>
</Layout>

<script>
  import '../scripts/stopwatch';
</script>
