---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<style>
  @import "../styles/home.css";
</style>

<Layout title="Início" activePage="home">
  <!-- HERO SECTION -->
  <section
    class="hero-section relative overflow-hidden flex flex-col items-center justify-center text-center px-6 py-32"
  >
    <!-- Background decorative blurs -->
    <div
      class="blur-decorative-one absolute top-1/4 left-1/4 w-96 h-96 rounded-full blur-[120px] pointer-events-none"
    >
    </div>
    <div
      class="blur-decorative-two absolute bottom-1/4 right-1/4 w-96 h-96 rounded-full blur-[120px] pointer-events-none"
    >
    </div>

    <!-- Tag badge -->
    <div class="tag-badge inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8">
      <span class="tag-badge-icon material-symbols-outlined">schedule</span>
      <span class="tag-badge-text text-xs font-bold uppercase tracking-widest">Gerenciador de Tempo</span>
    </div>

    <!-- Brand / Hero text -->
    <h1 class="brand-text mb-6">Orange Clockwork</h1>

    <!-- Tagline -->
    <p class="hero-tagline mb-4 max-w-2xl">Domine seu tempo. Mantenha o foco.</p>

    <!-- Subtitle -->
    <p class="section-subtext mb-12 max-w-xl">
      Três ferramentas de produtividade integradas para você trabalhar com mais
      eficiência e nunca mais perder o controle do seu tempo.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-wrap gap-4 justify-center">
      <a
        href={`${base}pomodoro`}
        class="btn-pomodoro flex items-center gap-3 px-8 py-4 rounded-full transition-all hover:scale-105 active:scale-95"
      >
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">timer</span>
        Começar com Pomodoro
      </a>
      <a
        href={`${base}stopwatch`}
        class="btn-ghost-cta flex items-center gap-3 px-8 py-4 font-medium transition-all hover:scale-105 active:scale-95"
      >
        <span class="material-symbols-outlined">stopwatch</span>
        Ver Cronômetro
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-hint absolute bottom-8 flex flex-col items-center gap-1">
      <span class="section-label" style="opacity: 0.4;">Explorar</span>
      <span class="material-symbols-outlined animate-bounce" style="color: var(--color-on-surface-variant); opacity: 0.4;">expand_more</span>
    </div>
  </section>

  <!-- FEATURES SECTION -->
  <section class="section-features px-6 md:px-12 py-24">
    <div class="max-w-6xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <span class="section-label">Funcionalidades</span>
        <h2 class="section-heading mt-3">Três Ferramentas.<br />Uma Missão.</h2>
        <p class="section-subtext mt-4 max-w-lg mx-auto">
          Cada ferramenta foi desenhada para uma necessidade específica de
          gestão de tempo, com uma interface limpa e sem distrações.
        </p>
      </div>

      <!-- Bento Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <!-- Pomodoro Card — Featured (dark, large) -->
        <div class="bento-card bento-card-featured md:col-span-7 relative overflow-hidden flex flex-col" style="min-height: 440px;">
          <!-- Decorative ring -->
          <div class="absolute -right-16 -bottom-16 opacity-10 pointer-events-none">
            <svg width="220" height="220" viewBox="0 0 220 220">
              <circle cx="110" cy="110" r="100" fill="none" stroke="#ff8c00" stroke-width="1.5" stroke-dasharray="6 4"></circle>
              <circle cx="110" cy="110" r="72" fill="none" stroke="#ff8c00" stroke-width="1" stroke-dasharray="3 5"></circle>
              <circle cx="110" cy="110" r="8" fill="#ff8c00"></circle>
              <line x1="110" y1="110" x2="110" y2="22" stroke="#ff8c00" stroke-width="2.5" stroke-linecap="round"></line>
              <line x1="110" y1="110" x2="162" y2="110" stroke="#ff8c00" stroke-width="1.5" stroke-linecap="round"></line>
            </svg>
          </div>

          <span class="card-label card-label-featured">Técnica de Foco</span>

          <div class="card-icon-wrap">
            <span class="material-symbols-outlined text-3xl" style="color: var(--color-primary); font-variation-settings: 'FILL' 1;">timer</span>
          </div>

          <h3 class="card-heading">Pomodoro</h3>

          <p class="card-body mb-6 flex-1">
            A técnica de produtividade mais eficaz do mundo. Ciclos de foco
            profundo intercalados com pausas estratégicas para maximizar seu
            rendimento.
          </p>

          <ul class="space-y-2 mb-8">
            {["25 min de foco + pausas programadas", "Rastreamento de sessões do dia", "Gestão de tarefa atual", "Avanço automático entre modos"].map((f) => (
              <li class="flex items-center gap-3">
                <span class="material-symbols-outlined" style="color: var(--color-tertiary); font-size: 1rem; font-variation-settings: 'FILL' 1;">check_circle</span>
                <span class="check-item-text">{f}</span>
              </li>
            ))}
          </ul>

          <a href={`${base}pomodoro`} class="btn-primary-cta inline-flex items-center gap-2 px-6 py-3 w-fit text-sm transition-all hover:scale-105 active:scale-95">
            Abrir Pomodoro
            <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_forward</span>
          </a>
        </div>

        <!-- Stopwatch Card -->
        <div class="bento-card bento-card-primary md:col-span-5 flex flex-col" style="min-height: 440px;">
          <span class="card-label">Medição de Tempo</span>

          <div class="card-icon-wrap">
            <span class="material-symbols-outlined text-3xl" style="color: var(--color-primary); font-variation-settings: 'FILL' 1;">stopwatch</span>
          </div>

          <h3 class="card-heading">Cronômetro</h3>

          <p class="card-body mb-6 flex-1">
            Precisão de centésimos de segundo com registro de voltas e
            estatísticas detalhadas para análise de desempenho.
          </p>

          <ul class="space-y-2 mb-8">
            {["Precisão em centésimos de segundo", "Registro e histórico de voltas", "Estatísticas de melhor e última volta"].map((f) => (
              <li class="flex items-center gap-3">
                <span class="material-symbols-outlined" style="color: var(--color-tertiary); font-size: 1rem; font-variation-settings: 'FILL' 1;">check_circle</span>
                <span class="check-item-text">{f}</span>
              </li>
            ))}
          </ul>

          <a href={`${base}stopwatch`} class="btn-secondary-cta inline-flex items-center gap-2 px-6 py-3 w-fit text-sm font-bold transition-all hover:scale-105 active:scale-95">
            Abrir Cronômetro
            <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_forward</span>
          </a>
        </div>

        <!-- Countdown Card — Full Width -->
        <div class="bento-card bento-card-secondary md:col-span-12 flex flex-col md:flex-row items-start gap-8 md:gap-16">
          <!-- Left -->
          <div class="flex-1 flex flex-col">
            <span class="card-label">Temporizador</span>

            <div class="card-icon-wrap card-icon-wrap-tertiary">
              <span class="material-symbols-outlined text-3xl" style="color: var(--color-tertiary); font-variation-settings: 'FILL' 1;">hourglass_bottom</span>
            </div>

            <h3 class="card-heading">Contagem Regressiva</h3>

            <p class="card-body" style="max-width: 38rem;">
              Defina um tempo personalizado ou escolha entre presets rápidos.
              Sons de alarme gerados proceduralmente avisam quando o tempo esgota.
            </p>
          </div>

          <!-- Right -->
          <div class="flex flex-col gap-6 md:w-80 shrink-0">
            <ul class="space-y-2">
              {["Tempo personalizado (HH:MM:SS)", "Presets rápidos: 15, 25, 45 e 90 min", "3 tons de alarme distintos", "Sons gerados via Web Audio API"].map((f) => (
                <li class="flex items-center gap-3">
                  <span class="material-symbols-outlined" style="color: var(--color-tertiary); font-size: 1rem; font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span class="check-item-text">{f}</span>
                </li>
              ))}
            </ul>

            <a href={`${base}countdown`} class="btn-secondary-cta inline-flex items-center gap-2 px-6 py-3 w-fit text-sm font-bold transition-all hover:scale-105 active:scale-95">
              Abrir Contagem Regressiva
              <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section-how-it-works px-6 md:px-12 py-24">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <span class="section-label">Como Funciona</span>
        <h2 class="section-heading mt-3">A Técnica Pomodoro</h2>
        <p class="section-subtext mt-4 max-w-lg mx-auto">
          Desenvolvida por Francesco Cirillo nos anos 80, esta técnica usa
          intervalos de tempo para melhorar foco e produtividade de forma
          sustentável.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
        {
          [
            { icon: "task_alt",       step: "01", title: "Defina a Tarefa",  desc: "Escolha o que você vai trabalhar durante a sessão e escreva no campo de foco.",            iconClass: "step-icon-wrap-primary",   iconColor: "var(--color-primary)",   stepColor: "var(--color-primary)"  },
            { icon: "timer",          step: "02", title: "Trabalhe 25 min",  desc: "Concentre-se completamente na tarefa por 25 minutos sem interrupções.",                   iconClass: "step-icon-wrap-primary",   iconColor: "var(--color-primary)",   stepColor: "var(--color-primary)"  },
            { icon: "coffee",         step: "03", title: "Pausa de 5 min",   desc: "Faça uma pausa curta para descansar a mente. Levante, alongue, respire.",                 iconClass: "step-icon-wrap-tertiary",  iconColor: "var(--color-tertiary)",  stepColor: "var(--color-tertiary)" },
            { icon: "self_improvement", step: "04", title: "Pausa Longa",   desc: "A cada 4 pomodoros, faça uma pausa de 15 minutos para recuperação completa.",              iconClass: "step-icon-wrap-tertiary",  iconColor: "var(--color-tertiary)",  stepColor: "var(--color-tertiary)" },
          ].map((item) => (
            <div class="step-card">
              <div class="flex items-start justify-between mb-4">
                <div class={`step-icon-wrap ${item.iconClass}`}>
                  <span class="material-symbols-outlined" style={`color: ${item.iconColor}; font-variation-settings: 'FILL' 1;`}>{item.icon}</span>
                </div>
                <span class="step-number" style={`color: ${item.stepColor};`}>{item.step}</span>
              </div>
              <h4 class="step-heading">{item.title}</h4>
              <p class="step-body">{item.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section-cta px-6 md:px-12 py-28 text-center relative overflow-hidden">
    <div class="cta-blur absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-72 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-2xl mx-auto relative z-10">
      <span class="cta-label">Comece Agora</span>
      <h2 class="cta-heading mt-4 mb-4">Seu tempo é o seu recurso mais valioso.</h2>
      <p class="cta-subtext mb-10">
        Escolha uma ferramenta e comece a trabalhar com mais foco e intenção a partir de agora.
      </p>

      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`${base}pomodoro`} class="btn-primary-cta flex items-center gap-3 px-8 py-4 text-base transition-all hover:scale-105 active:scale-95">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">timer</span>
          Iniciar Pomodoro
        </a>
        <a href={`${base}stopwatch`} class="btn-ghost-cta flex items-center gap-3 px-8 py-4 text-base transition-all hover:scale-105 active:scale-95">
          <span class="material-symbols-outlined">stopwatch</span>
          Cronômetro
        </a>
        <a href={`${base}countdown`} class="btn-ghost-cta flex items-center gap-3 px-8 py-4 text-base transition-all hover:scale-105 active:scale-95">
          <span class="material-symbols-outlined">hourglass_bottom</span>
          Contagem Regressiva
        </a>
      </div>
    </div>
  </section>
</Layout>
