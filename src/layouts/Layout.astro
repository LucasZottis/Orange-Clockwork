---
export interface Props {
  title: string;
  activePage: 'stopwatch' | 'pomodoro' | 'countdown' | 'home';
}

const { title, activePage } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Orange Clockwork</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500&family=Newsreader:ital,wght@0,700;1,700&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Top Navigation Bar -->
    <header class="header h-20 w-full sticky top-0 z-50">
      <div
        class="flex justify-between items-center px-12 w-full max-w-screen-2xl mx-auto h-full"
      >
        <a href={`${base}`} class="brand-link">
          Orange Clockwork
        </a>

        <nav class="hidden md:flex items-center gap-12">
          <a
            href={`${base}stopwatch`}
            class={`nav-item transition-colors duration-300 ${activePage === "stopwatch" ? "active-page" : ""}`}
          >
            Cronômetro
          </a>
          <a
            href={`${base}pomodoro`}
            class={`nav-item transition-colors duration-300 ${activePage === "pomodoro" ? "active-page" : ""}`}
          >
            Pomodoro
          </a>
          <a
            href={`${base}countdown`}
            class={`nav-item transition-colors duration-300 ${activePage === "countdown" ? "active-page" : ""}`}
          >
            Contagem Regressiva
          </a>
        </nav>

        <div class="flex items-center gap-6">
          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 btn-menu transition-all active:scale-95"
          >
            <span class="material-symbols-outlined">menu</span>
          </button>
        </div>
      </div>

      <!-- Mobile Navigation -->
      <div id="mobile-menu" class="hidden md:hidden w-full mobile-menu">
        <div class="flex flex-col px-6 py-4 gap-4">
          <a
            href={`${base}stopwatch`}
            class={`mobile-nav-link transition-colors duration-300 py-2 ${activePage === "stopwatch" ? "active-page" : ""}`}
          >
            Cronômetro
          </a>
          <a
            href={`${base}pomodoro`}
            class={`mobile-nav-link transition-colors duration-300 py-2 ${activePage === "pomodoro" ? "active-page" : ""}`}
          >
            Pomodoro
          </a>
          <a
            href={`${base}countdown`}
            class={`mobile-nav-link transition-colors duration-300 py-2 ${activePage === "countdown" ? "active-page" : ""}`}
          >
            Contagem Regressiva
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer w-full py-12">
      <div
        class="flex flex-col md:flex-row justify-between items-center px-12 gap-6 w-full max-w-screen-2xl mx-auto footer-meta"
      >
        <div class="flex gap-8">
          <a href="#" class="footer-link transition-opacity">Política de Privacidade</a>
          <a href="#" class="footer-link transition-opacity">Termos de Serviço</a>
          <a href="#" class="footer-link transition-opacity">Suporte</a>
        </div>
        <p class="footer-link">
          © 2024 Chronos Focus. The Obsidian Gallery.
        </p>
      </div>
    </footer>

    <script>
      const btn = document.getElementById("mobile-menu-btn");
      const menu = document.getElementById("mobile-menu");
      btn?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
