---
export interface Props {
  title: string;
  activePage: 'stopwatch' | 'pomodoro' | 'countdown';
}

const { title, activePage } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Chronos Focus</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500&family=Newsreader:ital,wght@0,700;1,700&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col" style="background-color: #f9f9fe; color: #191c1f;">
    <!-- Top Navigation Bar -->
    <header class="h-20 w-full sticky top-0 z-50" style="background-color: #150c0c;">
      <div class="flex justify-between items-center px-12 w-full max-w-screen-2xl mx-auto h-full">
        <div style="font-family: 'Newsreader', serif; font-size: 1.5rem; font-weight: 700; font-style: italic; color: #f1dedd;">
          Chronos Focus
        </div>

        <nav class="hidden md:flex items-center gap-12">
          <a
            href="/stopwatch"
            class="transition-colors duration-300"
            style={`font-family: 'Manrope', sans-serif; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: ${activePage === 'stopwatch' ? '#ffb3b0' : 'rgba(241,222,221,0.7)'}; font-weight: ${activePage === 'stopwatch' ? '700' : '400'}; ${activePage === 'stopwatch' ? 'border-bottom: 2px solid #af4949; padding-bottom: 0.25rem;' : ''}`}
          >
            Cronômetro
          </a>
          <a
            href="/pomodoro"
            class="transition-colors duration-300"
            style={`font-family: 'Manrope', sans-serif; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: ${activePage === 'pomodoro' ? '#ffb3b0' : 'rgba(241,222,221,0.7)'}; font-weight: ${activePage === 'pomodoro' ? '700' : '400'}; ${activePage === 'pomodoro' ? 'border-bottom: 2px solid #af4949; padding-bottom: 0.25rem;' : ''}`}
          >
            Pomodoro
          </a>
          <a
            href="/countdown"
            class="transition-colors duration-300"
            style={`font-family: 'Manrope', sans-serif; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: ${activePage === 'countdown' ? '#ffb3b0' : 'rgba(241,222,221,0.7)'}; font-weight: ${activePage === 'countdown' ? '700' : '400'}; ${activePage === 'countdown' ? 'border-bottom: 2px solid #af4949; padding-bottom: 0.25rem;' : ''}`}
          >
            Contagem Regressiva
          </a>
        </nav>

        <div class="flex items-center gap-6">
          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 transition-all active:scale-95" style="color: rgba(241,222,221,0.7);">
            <span class="material-symbols-outlined">menu</span>
          </button>
        </div>
      </div>

      <!-- Mobile Navigation -->
      <div id="mobile-menu" class="hidden md:hidden w-full" style="background-color: #1a0d0d;">
        <div class="flex flex-col px-6 py-4 gap-4">
          <a
            href="/stopwatch"
            class="transition-colors duration-300 py-2"
            style={`font-family: 'Manrope', sans-serif; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: ${activePage === 'stopwatch' ? '#ffb3b0' : 'rgba(241,222,221,0.7)'}; font-weight: ${activePage === 'stopwatch' ? '700' : '400'};`}
          >
            Cronômetro
          </a>
          <a
            href="/pomodoro"
            class="transition-colors duration-300 py-2"
            style={`font-family: 'Manrope', sans-serif; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: ${activePage === 'pomodoro' ? '#ffb3b0' : 'rgba(241,222,221,0.7)'}; font-weight: ${activePage === 'pomodoro' ? '700' : '400'};`}
          >
            Pomodoro
          </a>
          <a
            href="/countdown"
            class="transition-colors duration-300 py-2"
            style={`font-family: 'Manrope', sans-serif; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: ${activePage === 'countdown' ? '#ffb3b0' : 'rgba(241,222,221,0.7)'}; font-weight: ${activePage === 'countdown' ? '700' : '400'};`}
          >
            Contagem Regressiva
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="w-full py-12 border-t" style="background-color: #1a1111; border-color: rgba(241,222,221,0.1);">
      <div class="flex flex-col md:flex-row justify-between items-center px-12 gap-6 w-full max-w-screen-2xl mx-auto">
        <div class="flex gap-8" style="font-family: 'Manrope', sans-serif; font-size: 0.75rem; letter-spacing: 0.05em;">
          <a href="#" class="transition-opacity hover:opacity-100" style="color: rgba(241,222,221,0.5);">Política de Privacidade</a>
          <a href="#" class="transition-opacity hover:opacity-100" style="color: rgba(241,222,221,0.5);">Termos de Serviço</a>
          <a href="#" class="transition-opacity hover:opacity-100" style="color: rgba(241,222,221,0.5);">Suporte</a>
        </div>
        <p style="color: rgba(241,222,221,0.5); font-family: 'Manrope', sans-serif; font-size: 0.75rem; letter-spacing: 0.05em;">
          © 2024 Chronos Focus. The Obsidian Gallery.
        </p>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
